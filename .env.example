# QRForge Environment Configuration

# Application Settings
APP_PORT=8081
FRONTEND_PORT=3001
APP_ENV=production

# QR Code Settings
ENABLE_HISTORY=true
MAX_PAYLOAD_SIZE=5000
DEFAULT_QR_SIZE=512

# Security Settings
CORS_ORIGINS=http://localhost:3001,http://localhost:8081
# RATE_LIMIT_PER_MINUTE=60

# Optional: Database for persistent history (future feature)
# DATABASE_URL=sqlite:///app/data/qrforge.db
